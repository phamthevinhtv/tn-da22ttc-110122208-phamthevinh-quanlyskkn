@model DoiMatKhauVM

@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="h-screen flex justify-center items-center p-3">
    <div class="card shadow-md border border-base-300 p-6 w-100">
        <div class="flex items-center justify-center gap-3 pb-3 border-b border-base-300">
            <img src="~/images/logo.png" alt="Logo" class="w-10">
            <p class="text-lg font-medium italic text-primary">Sáng kiến kinh nghiệm</p>
        </div>
        <h1 class="text-lg font-medium text-center my-3">Đổi mật khẩu</h1>
        <form method="post" asp-action="DoiMatKhau" asp-controller="TaiKhoan" class="flex flex-col gap-3">
            <label>
                Mật khẩu
                <input type="password" asp-for="MatKhauCu" class="input w-full mt-1" placeholder="Nhập mật khẩu cũ">
                <span asp-validation-for="MatKhauCu" class="text-error text-sm"></span>
            </label>
            <label>
                Xác nhận mật khẩu
                <input type="password" asp-for="XacNhanMatKhauCu" class="input w-full mt-1" placeholder="Nhập lại mật khẩu">
                <span asp-validation-for="XacNhanMatKhauCu" class="text-error text-sm"></span>
            </label>
            <label>
                Mật khẩu mới
                <input type="password" asp-for="MatKhauMoi" class="input w-full mt-1" placeholder="Nhập mật khẩu mới">
                <span asp-validation-for="MatKhauMoi" class="text-error text-sm"></span>
            </label>
            <label>
                Xác nhận mật khẩu mới
                <input type="password" asp-for="XacNhanMatKhauMoi" class="input w-full mt-1" placeholder="Nhập lại mật khẩu mới">
                <span asp-validation-for="XacNhanMatKhauMoi" class="text-error text-sm"></span>
            </label>
            <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>
            <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Đổi mật khẩu</button>
            <a asp-action="Index" asp-controller="Home" class="btn btn-soft font-normal shadow-none">Thoát</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@if (TempData["Success"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-success">
            <span class="text-white">@TempData["Success"]</span>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-error">
            <span class="text-white">@TempData["Error"]</span>
        </div>
    </div>
}

<script>
    setTimeout(() => {
        document.getElementById('toast')?.remove();
    }, 3000);
</script>
