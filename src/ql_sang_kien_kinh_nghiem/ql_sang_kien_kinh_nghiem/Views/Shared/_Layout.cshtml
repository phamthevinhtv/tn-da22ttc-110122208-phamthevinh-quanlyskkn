@using System.Security.Claims

@{
    var hoTen = User.Identity?.Name ?? "";
    var hoTenSplit = hoTen.Split(" ");
    var ten = hoTenSplit[hoTenSplit.Count() - 1];

    string? quyen = User.FindFirst(ClaimTypes.Role)?.Value;
    string? tenVaiTroHD = User.FindFirst("TenVaiTroHD")?.Value;
}

<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen flex flex-col">
        <header class="px-3 py-2 border-b border-base-300 flex items-center justify-between flex-wrap md:flex-nowrap gap-3">
            <div class="flex items-center gap-3 order-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="var(--color-base-content)" class="md:hidden cursor-pointer" id="btn_open_fixed_sidebar">
                    <path d="M166.15-274.15v-36.93h627.7v36.93h-627.7Zm0-187.7v-36.92h627.7v36.92h-627.7Zm0-187.69v-36.92h627.7v36.92h-627.7Z"/>
                </svg>
                <a href="/" class="flex items-center gap-3">
                    <img src="~/images/logo.png" alt="Logo" class="w-10">
                    <p class="text-lg font-medium italic text-primary">Sáng kiến kinh nghiệm</p>
                </a>
            </div>
            @if(quyen == "BGD" || quyen == "DVTT" || quyen == "CBGV") {
                <form asp-action="TimKiem" asp-controller="SangKien" method="get" class="w-full max-w-full md:max-w-96 order-3 md:order-2">
                    <div class="join w-full">
                        <input type="text" required name="tukhoa" class="input input-primary join-item focus:outline-none w-full" placeholder="Nhập từ khóa liên quan đến sáng kiến cần tìm">
                        <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none join-item">Tìm</button>
                    </div>
                </form>
            }
            <div class="dropdown dropdown-end cursor-pointer order-2 md:order-3 ml-auto md:ml-0 shrink-0">
                <div tabindex="0" role="button" class="flex items-center gap-2">
                    <img src="https://api.dicebear.com/10.x/initials/svg/seed=@ten" alt="Avatar" class="w-10 rounded-full">
                    <div>
                        <p>@User.Identity?.Name</p>
                        <p class="text-xs text-base-content/70">
                            @switch(quyen) {
                                case "BGD":
                                    @:Cấp ban giám đốc
                                    break;
                                case "DVTT":
                                    @:Cấp đơn vị trực thuộc
                                    break;
                                case "CBGV":
                                    @:Cấp cán bộ/giảng viên
                                    break;
                                case "ADMIN":
                                    @:Cấp quản trị tài khoản
                                    break;
                                default:
                                    @:Khách
                                    break;
                            }
                            @if (!string.IsNullOrEmpty(tenVaiTroHD)) {
                                <p class="text-xs text-base-content/70">@tenVaiTroHD</p>
                            }
                        </p>
                    </div>
                </div>
                <ul tabindex="-1" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-fit p-2 shadow">
                    <li>
                        <a asp-action="CaNhan" asp-controller="TaiKhoan" class="white-space-nowrap">
                            Thông tin cá nhân
                        </a>
                    </li>
                    <li>
                        <a asp-action="DoiMatKhau" asp-controller="TaiKhoan" class="white-space-nowrap">
                            Đổi mật khẩu
                        </a>
                    </li>
                    <li>
                        <form asp-action="DangXuat" asp-controller="TaiKhoan" method="post">
                            <button class="bg-transparent border-0 p-0 m-0 cursor-pointer text-red-500 font-normal">
                                Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </header>
        <div class="flex grow overflow-hidden">
            <aside class="hidden md:block border-r border-base-300 py-3 overflow-y-auto w-42 shrink-0">
                <partial name="_SidebarListPartial" model="quyen"/>  
            </aside>
            <div class="flex flex-col grow overflow-y-auto">
                <main class="grow">
                    @RenderBody()
                </main>
                <footer class="border-t border-base-300 p-2">
                    <p class="text-center text-xs">&copy; 2026 Trường Đại học A</p>
                </footer>
            </div>
        </div>
    </div>

    <div class="md:hidden fixed inset-0 z-100 bg-black/40 opacity-0 invisible transition-all duration-200" id="overlay"></div>

    <aside class="md:hidden fixed top-0 left-0 bottom-0 z-101 bg-base-100 w-42 shrink-0 -translate-x-full transition-transform duration-200 flex flex-col h-full" id="fixed_sidebar">
        <div class="flex items-center gap-3 pl-3 pr-2 py-2 mb-3 justify-between border-b border-base-300 shrink-0">
            <a href="/">
                <img src="~/images/logo.png" alt="Logo" class="w-10">
            </a>
            <svg xmlns="http://w3.org" height="24px" viewBox="0 -960 960 960" width="24px" fill="var(--color-base-content)" class="cursor-pointer" id="btn_close_fixed_sidebar">
                <path d="M257.85-231.38 232-257.85 453.54-480 232-702.15l25.85-26.47L480-506.46l222.15-222.16L728-702.15 506.46-480 728-257.85l-25.85 26.47L480-453.54 257.85-231.38Z"/>
            </svg>
        </div>
        <div class="overflow-y-auto flex-1">
            <partial name="_SidebarListPartial" model="quyen" />  
        </div>
    </aside>
        
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
