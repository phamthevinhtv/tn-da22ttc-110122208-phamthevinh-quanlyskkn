@model HoiDongVM

@{
    ViewData["Title"] = (Model.MaHD > 0 ? "Chi tiết " : "Thêm ") + "hội đồng";
    int sttcbgvvt = 1;
}

<div class="p-3">
    <div class="flex justify-between items-center mb-3 flex-wrap gap-3">
        <h2 class="text-lg font-medium">@ViewData["Title"]</h2>
        @if(Model.MaHD > 0) {
            <a asp-action="ChiTiet" asp-controller="HoiDong" class="btn btn-outline btn-primary btn-sm hover:text-base-100 font-normal shadow-none">Thêm hội đồng</a>
        }
    </div>
    <div class="border border-base-300 p-3 rounded-box">
        <form method="post" asp-action="ChiTiet" asp-controller="HoiDong" class="flex flex-col gap-3 mb-3">
            <input type="hidden" asp-for="MaHD">
            <label>
                Tên hội đồng
                <input type="text" asp-for="TenHD" class="input w-full mt-1" placeholder="Nhập tên hội đồng">
                <span asp-validation-for="TenHD" class="text-error text-sm"></span>
            </label>
            <label>
                Căn cứ thành lập hội đồng
                <textarea asp-for="CanCu" class="textarea w-full mt-1" placeholder="Nhập căn cứ thành lập hội đồng"></textarea>
                <span asp-validation-for="CanCu" class="text-error text-sm"></span>
            </label>
            <label>
                Điều khoản thành lập hội đồng
                <textarea asp-for="DieuKhoan" class="textarea w-full mt-1" placeholder="Nhập điều khoản thành lập hội đồng"></textarea>
                <span asp-validation-for="DieuKhoan" class="text-error text-sm"></span>
            </label>
            <label>
                Ngày thành lập hội đồng
                <input type="date" asp-for="NgayLap" class="input w-full mt-1">
                <span asp-validation-for="NgayLap" class="text-error text-sm"></span>
            </label>
            <label>
                Ngày kết thúc hội đồng
                <input type="date" asp-for="NgayKetThuc" class="input w-full mt-1">
                <span asp-validation-for="NgayKetThuc" class="text-error text-sm"></span>
            </label>
            <div class="flex gap-3 justify-between items-center flex-wrap">
                <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>
                <div class="flex gap-3 ml-auto">
                    <a asp-action="Index" asp-controller="HoiDong" class="btn btn-soft font-normal shadow-none">Thoát</a>
                    <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Lưu</button>
                </div>
            </div>
        </form>
        @if(Model.MaHD > 0) {
            <div class="border-t border-base-300 pt-3">
                <div class="flex justify-between items-center mb-3 flex-wrap">
                    <h3 class="text-base">Thành viên hội đồng</h3>
                    <button class="btn btn-outline btn-primary btn-sm hover:text-base-100 font-normal shadow-none" onclick="document.getElementById('them_thanh_vien_hd_modal').showModal()">Thêm thành viên</button>
                </div>
                <div class="overflow-x-auto rounded-box border border-base-300">
                    <table class="table">
                        <thead>
                            <tr>
                                <th class="p-2 text-base-content w-20">STT</th>
                                <th class="p-2 text-base-content">Tên thành viên</th>
                                <th class="p-2 text-base-content">Vai trò</th>
                                <th class="p-2 text-base-content w-20">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.DSCBGVVaiTro != null && Model.DSCBGVVaiTro.Count > 0) {
                                @foreach(var cBGVVaiTro in @Model.DSCBGVVaiTro) {
                                    var xoaThanhVienModalId = $"xoa_thanh_vien_modal_{cBGVVaiTro.MaHD}_{cBGVVaiTro.MaCBGV}_{cBGVVaiTro.MaVT}";
                                    <tr class="align-top">
                                        <td class="p-2">
                                            @sttcbgvvt
                                        </td>
                                        <td class="p-2">
                                            @cBGVVaiTro.HoTen
                                        </td>
                                        <td class="p-2">
                                            @cBGVVaiTro.TenVT
                                        </td>
                                        <td class="p-2">
                                            <div class="flex items-center gap-2">
                                                <button class="btn-ghost flex cursor-pointer tooltip tooltip-left" data-tip="Xóa thành viên" onclick="document.getElementById('@xoaThanhVienModalId').showModal()">
                                                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="var(--color-error)">
                                                        <path d="m336-310.81 144-144 144 144L649.58-336l-144-144 144-144L624-649.58l-144 144-144-144L310.81-624l144 144-144 144L336-310.81ZM226.89-165.54q-25.75 0-43.55-17.8-17.8-17.8-17.8-43.55v-506.22q0-25.75 17.8-43.55 17.8-17.8 43.55-17.8h506.22q25.75 0 43.55 17.8 17.8 17.8 17.8 43.55v506.22q0 25.75-17.8 43.55-17.8 17.8-43.55 17.8H226.89Zm.19-36.92h505.84q9.23 0 16.93-7.69 7.69-7.7 7.69-16.93v-505.84q0-9.23-7.69-16.93-7.7-7.69-16.93-7.69H227.08q-9.23 0-16.93 7.69-7.69 7.7-7.69 16.93v505.84q0 9.23 7.69 16.93 7.7 7.69 16.93 7.69Zm-24.62-555.08V-202.46-757.54Z"/>
                                                    </svg>
                                                </button>

                                                <dialog id="@xoaThanhVienModalId" class="modal">
                                                    <div class="modal-box p-3">
                                                        <h3 class="text-lg font-medium">
                                                            Xác nhận
                                                        </h3>
                                                        <p class="text-base mb-3 mt-2">
                                                            Bạn có chắc chắn muốn xóa thành viên này không?
                                                        </p>
                                                        <form method="post" asp-action="XoaThanhVien" asp-controller="HoiDong" class="flex flex-col gap-3">
                                                            <input type="hidden" name="MaHD" value="@cBGVVaiTro.MaHD">
                                                            <input type="hidden" name="MaCBGV" value="@cBGVVaiTro.MaCBGV">
                                                            <input type="hidden" name="MaVT" value="@cBGVVaiTro.MaVT">
                                                            <div class="modal-action mt-0 gap-3 ml-auto">
                                                                <button type="button" class="btn btn-soft font-normal shadow-none" onclick="document.getElementById('@xoaThanhVienModalId').close()">Thoát</button>
                                                                <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Xóa</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </dialog>
                                            </div>
                                        </td>
                                    </tr>
                                    sttcbgvvt++; 
                                }
                            } else {
                                <tr>
                                    <td colspan="6" class="text-center">Danh sách rỗng</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<dialog id="them_thanh_vien_hd_modal" class="modal">
    <div class="modal-box p-3">
        <h3 class="text-lg font-medium mb-3">
            Thêm thành viên hội đồng
        </h3>
        <form method="post" asp-action="LuuCBGVVT" asp-controller="HoiDong" class="flex flex-col gap-3">
            <input type="hidden" name="MaHD" value="@Model.MaHD">
            <label>
                Tên thành viên
                <select name="MaCBGV" asp-items="Model.DSCanBoGiangVien" class="select w-full mt-1">
                    <option disabled selected>Chọn tên thành viên</option>
                </select>
                <span class="text-error text-sm"></span>
            </label>
            <label>
                Vai trò
                <select name="MaVT" asp-items="Model.DSVaiTro" class="select w-full mt-1">
                    <option disabled selected>Chọn vai trò</option>
                </select>
                <span class="text-error text-sm"></span>
            </label>
            <div class="modal-action mt-0 gap-3 ml-auto">
                <button type="button" class="btn btn-soft font-normal shadow-none" onclick="document.getElementById('them_thanh_vien_hd_modal').close()">Thoát</button>
                <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Lưu</button>
            </div>
        </form>
    </div>
</dialog>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@if (TempData["Success"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-success">
            <span class="text-white">@TempData["Success"]</span>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-error">
            <span class="text-white">@TempData["Error"]</span>
        </div>
    </div>
}

<script>
    setTimeout(() => {
        document.getElementById('toast')?.remove();
    }, 3000);
</script>