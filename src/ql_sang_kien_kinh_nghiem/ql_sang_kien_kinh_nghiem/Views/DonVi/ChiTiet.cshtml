@model DonViVM

@{
    ViewData["Title"] = (Model.MaDV > 0 ? "Chi tiết " : "Thêm ") + "đơn vị";
}

<div class="p-3">
    <div class="flex justify-between items-center mb-3 flex-wrap gap-3">
        <h2 class="text-lg font-medium">@ViewData["Title"]</h2>
        @if(Model.MaDV > 0) {
            <a asp-action="ChiTiet" asp-controller="DonVi" class="btn btn-outline btn-primary btn-sm hover:text-base-100 font-normal shadow-none">Thêm đơn vị</a>
        }
    </div>

    <form method="post" asp-action="ChiTiet" asp-controller="DonVi" class="border border-base-300 p-3 rounded-box flex flex-col gap-3">
        <input type="hidden" asp-for="MaDV">
        <label>
            Đơn vị quản lý
            <select asp-for="MaDVCha" asp-items="Model.DSDonViCha" class="select w-full mt-1">
                <option value="">Chọn đơn vị quản lý</option>
            </select>
            <span asp-validation-for="MaDVCha" class="text-error text-sm"></span>
        </label>
        <label>
            Tên đơn vị
            <input type="text" asp-for="TenDV" class="input w-full mt-1" placeholder="Nhập tên đơn vị">
            <span asp-validation-for="TenDV" class="text-error text-sm"></span>
        </label>
        <label>
            Email
            <input type="email" asp-for="Email" class="input w-full mt-1" placeholder="Nhập email">
            <span asp-validation-for="Email" class="text-error text-sm"></span>
        </label>
        <label>
            Số điện thoại
            <input type="text" asp-for="SoDienThoai" class="input w-full mt-1" placeholder="Nhập số điện thoại">
            <span asp-validation-for="SoDienThoai" class="text-error text-sm"></span>
        </label>
        <div class="flex gap-3 justify-between items-center flex-wrap">
            <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>
            <div class="flex gap-3 ml-auto">
                <a asp-action="Index" asp-controller="DonVi" class="btn btn-soft font-normal shadow-none">Thoát</a>
                <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Lưu</button>
            </div>
        </div>
    </form>
    @if(Model.MaDV > 0) {
        <div class="border-t border-base-300 pt-3 mt-3">
            <div class="flex justify-between items-center mb-3 flex-wrap">
                <h3 class="text-base">Đơn vị trực thuộc</h3>
                <button class="btn btn-outline btn-primary btn-sm hover:text-base-100 font-normal shadow-none" onclick="document.getElementById('them_don_vi_con_modal').showModal()">Thêm đơn vị trực thuộc</button>
            </div>
            <div class="overflow-x-auto rounded-box border border-base-300">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="p-2 text-base-content w-20">STT</th>
                            <th class="p-2 text-base-content">Tên đơn vị</th>
                            <th class="p-2 text-base-content">Email</th>
                            <th class="p-2 text-base-content">Số điện thoại</th>
                            <th class="p-2 text-base-content w-20">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var stt = 1;
                        }
                        @if(Model.DSDonViCon != null && Model.DSDonViCon.Count > 0) {
                            @foreach(var dv in Model.DSDonViCon) {
                                <tr class="align-top">
                                    <td class="p-2">@stt</td>
                                    <td class="p-2">@dv.TenDV</td>
                                    <td class="p-2">@dv.Email</td>
                                    <td class="p-2">@dv.SoDienThoai</td>
                                    <td class="p-2">
                                        <div class="flex items-center gap-2">
                                            <button class="btn-ghost flex cursor-pointer tooltip tooltip-left" onclick="document.getElementById('xoa_dvc_modal_@(dv.MaDV)').showModal()" data-tip="Xóa đơn vị">
                                                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="var(--color-error)">
                                                    <path d="m336-310.81 144-144 144 144L649.58-336l-144-144 144-144L624-649.58l-144 144-144-144L310.81-624l144 144-144 144L336-310.81ZM226.89-165.54q-25.75 0-43.55-17.8-17.8-17.8-17.8-43.55v-506.22q0-25.75 17.8-43.55 17.8-17.8 43.55-17.8h506.22q25.75 0 43.55 17.8 17.8 17.8 17.8 43.55v506.22q0 25.75-17.8 43.55-17.8 17.8-43.55 17.8H226.89Zm.19-36.92h505.84q9.23 0 16.93-7.69 7.69-7.7 7.69-16.93v-505.84q0-9.23-7.69-16.93-7.7-7.69-16.93-7.69H227.08q-9.23 0-16.93 7.69-7.69 7.7-7.69 16.93v505.84q0 9.23 7.69 16.93 7.7 7.69 16.93 7.69Zm-24.62-555.08V-202.46-757.54Z"/>
                                                </svg>
                                            </button>

                                            <dialog id="xoa_dvc_modal_@(dv.MaDV)" class="modal">
                                                <div class="modal-box p-3">
                                                    <h3 class="text-lg font-medium">Xác nhận</h3>
                                                    <p class="text-base mb-3 mt-2">Bạn có chắc chắn muốn xóa đơn vị "@dv.TenDV" khỏi đơn vị quản lý không?</p>
                                                    <form method="post" asp-action="XoaDonViCon" asp-controller="DonVi" class="flex flex-col gap-3">
                                                        <input type="hidden" name="maDVCon" value="@dv.MaDV" />
                                                        <div class="modal-action mt-0 gap-3 ml-auto">
                                                            <button type="button" class="btn btn-soft font-normal shadow-none" onclick="document.getElementById('xoa_dvc_modal_@(dv.MaDV)').close()">Thoát</button>
                                                            <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Xóa</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </dialog>
                                        </div>
                                    </td>
                                </tr>
                                stt++;
                            }
                        } else {
                            <tr>
                                <td colspan="5" class="p-2 text-center">Danh sách rỗng</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<dialog id="them_don_vi_con_modal" class="modal">
    <div class="modal-box p-3">
        <h3 class="text-lg font-medium mb-3">Chi tiết đơn vị trực thuộc</h3>
        <form method="post" asp-action="LuuDonViCon" asp-controller="DonVi" class="flex flex-col gap-3">
            <input type="hidden" asp-for="MaDVCha" value="@Model.MaDV" />
            <label>
                Chọn đơn vị trực thuộc
                <select asp-for="MaDVCon" asp-items="Model.DSDonViConSelect" class="select w-full mt-1">
                    <option value="">Chọn đơn vị trực thuộc</option>
                </select>
                <span asp-validation-for="MaDVCon" class="text-error text-sm"></span>
            </label>
            <div class="modal-action mt-0 gap-3 ml-auto">
                <button type="button" class="btn btn-soft font-normal shadow-none" onclick="document.getElementById('them_don_vi_con_modal').close()">Thoát</button>
                <button type="submit" class="btn btn-primary text-base-100 font-normal shadow-none">Lưu</button>
            </div>
        </form>
    </div>
</dialog>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@if (TempData["Success"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-success">
            <span class="text-white">@TempData["Success"]</span>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-error">
            <span class="text-white">@TempData["Error"]</span>
        </div>
    </div>
}

<script>
    setTimeout(() => {
        document.getElementById('toast')?.remove();
    }, 3000);
</script>
