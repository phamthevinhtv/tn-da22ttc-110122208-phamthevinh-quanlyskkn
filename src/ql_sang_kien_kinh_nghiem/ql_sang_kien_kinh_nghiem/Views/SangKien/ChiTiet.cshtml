@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@if (TempData["Success"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-success">
            <span class="text-white">@TempData["Success"]</span>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="toast" class="toast toast-top toast-end">
        <div class="alert alert-error">
            <span class="text-white">@TempData["Error"]</span>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        setTimeout(() => {
            document.getElementById('toast')?.remove();
        }, 3000);

        const inputFile = document.getElementById("FileDinhKem");
        const loiFile = document.querySelector('[data-valmsg-for="FileDinhKem"]');

        inputFile.addEventListener("change", function () {
            loiFile.textContent = "";
            const file = this.files[0];

            if (!file) return;

            const allowedExtensions = [
                ".pdf",
                ".doc",
                ".docx"
            ];

            const fileName = file.name.toLowerCase();

            const isValidExtension = allowedExtensions.some(ext =>
                fileName.endsWith(ext)
            );

            if (!isValidExtension) {
                loiFile.textContent = "Chỉ chấp nhận file PDF hoặc Word";
                this.value = "";

                return;
            }

            const maxSize = 10 * 1024 * 1024; 

            if (file.size > maxSize) {
                loiFile.textContent = "Kích thước file tối đa 10MB";
                this.value = "";

                return;
            }
        });

        const ngayInput = document.getElementById("NgayApDung");
        const loiNgayApDung = document.querySelector('[data-valmsg-for="NgayApDung"]');

        ngayInput.addEventListener("change", function () {

            loiNgayApDung.textContent = "";

            if (!this.value) return;

            const selectedDate = new Date(this.value);

            const today = new Date();
            today.setHours(0, 0, 0, 0);

            const oneYearAgo = new Date(today);
            oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);

            if (selectedDate > today) {

                loiNgayApDung.textContent = "Ngày áp dụng phải trước ngày hiện tại";

            } else if (selectedDate < oneYearAgo) {

                loiNgayApDung.textContent = "Ngày áp dụng không được quá 01 năm tính đến hiện tại";
            }
        });

        const soThanhVien = @(Model?.DSCanBoGiangVienSK != null ? Model.DSCanBoGiangVienSK.Count : 0);
        const maSK = @(Model?.MaSK ?? 0);

        if (soThanhVien <= 0 && maSK > 0) {
            document.getElementById('them_thanh_vien_sang_kien_modal').showModal()
        }
    });
</script>